MCP_TRANSPORT=http
MCP_HOST=0.0.0.0
MCP_PORT=3100

# Firecrawl backend
FIRECRAWL_API_URL=http://localhost:3002
FIRECRAWL_API_KEY=local-dev-key
FIRECRAWL_CACHE_TTL_MS=1800000
FIRECRAWL_MAX_DISCOVERY_DEPTH=2
FIRECRAWL_MAX_DISCOVERY_PAGES=8

# Memory runtime
CDU_MEMORY_ENABLED=false
CDU_MEMORY_FILE_PATH=../cdufireseach-memory.md
CDU_MEMORY_CANDIDATE_FILE_PATH=../cdufireseach-memory-candidates.md
CDU_MEMORY_CACHE_TTL_MS=300000
CDU_MEMORY_AUTO_WRITE_ENABLED=false

# LLM runtime (Volcengine ARK / OpenAI-compatible)
CDU_LLM_BASE_URL=
CDU_LLM_API_KEY=
CDU_LLM_MODEL=
CDU_LLM_TEMPERATURE=0.2
CDU_LLM_TIMEOUT_MS=20000
