{
  "name": "cdufireseach",
  "version": "0.1.0",
  "description": "MVP MCP server for Chengdu University site data queries",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "dev": "tsx src/index.ts",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "mcp",
    "typescript",
    "firecrawl",
    "cdu"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.11",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
