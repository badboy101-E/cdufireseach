# Copy this file to .env before first start.

# Public ports
FIRECRAWL_PUBLIC_PORT=3002
MCP_PUBLIC_PORT=3000

# Firecrawl core
USE_DB_AUTHENTICATION=false
BULL_AUTH_KEY=change-this-admin-secret
POSTGRES_USER=firecrawl
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_DB=firecrawl

# MCP shim
# Firecrawl MCP documents API key as optional for self-hosted mode, but keeping
# a non-empty value avoids version-specific MCP startup issues seen in the wild.
FIRECRAWL_API_KEY=local-dev-key

# Optional AI extraction support for /extract and JSON scrape formats
OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=
MODEL_EMBEDDING_NAME=
OLLAMA_BASE_URL=

# Optional outbound proxy for harder targets
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional search override. Without this, self-hosted Firecrawl uses Google.
# A self-hosted SearXNG is usually easier to control in private environments.
SEARXNG_ENDPOINT=
SEARXNG_ENGINES=
SEARXNG_CATEGORIES=

# Tuning
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_JOBS=5
BROWSER_POOL_SIZE=5
LOGGING_LEVEL=info
ALLOW_LOCAL_WEBHOOKS=false
BLOCK_MEDIA=false

# MCP retry behavior
FIRECRAWL_RETRY_MAX_ATTEMPTS=5
FIRECRAWL_RETRY_INITIAL_DELAY=1000
FIRECRAWL_RETRY_MAX_DELAY=10000
FIRECRAWL_RETRY_BACKOFF_FACTOR=2
